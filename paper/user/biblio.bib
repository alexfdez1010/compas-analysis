% ==========================================================
% BIBLIO.BIB — Your reference database (BibTeX format)
% ==========================================================
%
% Add one entry per reference below, then cite it in
% 'user/content.tex' with \cite{yourkey}. The three entries
% below are worked EXAMPLES showing the most common entry
% types (journal article, conference paper, book) — replace
% them with your own references and delete these once you no
% longer need them for reference.
%
% Each entry's citation key (the word right after the opening
% brace, e.g. "ExampleJournalArticle2024") must be unique and is
% what you type inside \cite{...}.
% ==========================================================

@article{ExampleJournalArticle2024,
  author  = {Surname, First Name and Surname, First Name},
  title   = {Title of the Journal Article},
  journal = {Name of the Journal},
  year    = {2024},
  volume  = {1},
  number  = {1},
  pages   = {1--10},
  doi     = {10.0000/example.doi}
}

@inproceedings{ExampleConferencePaper2024,
  author    = {Surname, First Name},
  title     = {Title of the Conference Paper},
  booktitle = {Proceedings of the Example Conference},
  year      = {2024},
  pages     = {1--6},
  doi       = {10.0000/example.doi}
}

@book{ExampleBook2024,
  author    = {Surname, First Name},
  title     = {Title of the Book},
  publisher = {Publisher Name},
  year      = {2024}
}
